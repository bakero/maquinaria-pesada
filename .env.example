# Copia este archivo como .env y rellena con tus claves reales.
# El archivo .env esta en .gitignore y NUNCA debe subirse a git.

# --- Obligatorias para el pipeline principal ---------------------------
# Generacion de audio (ElevenLabs TTS) — generar_episodio_v2.py
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# Generacion de guiones (Anthropic Claude) — generar_guion.py / cockpit
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key_here

# --- Opcionales (cockpit web y conectores) -----------------------------
# Debate dual GPT y health-check de API keys en el cockpit
OPENAI_API_KEY=sk-your_openai_key_here
# Generacion de video (Kling)
KLING_API_KEY=your_kling_key_here

# Analytics de difusion (cockpit/connectors/analytics/spotify.py)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Spotify for Podcasters (scraping autenticado) — alternativa a la API publica
SPOTIFY_SP_DC=
SPOTIFY_SP_KEY=
SPOTIFY_PODCAST_ID=

# --- Overrides de entorno (normalmente NO hace falta tocarlos) ---------
# Raiz del repo si ejecutas el cockpit contra otro checkout
# REPO_ROOT=/ruta/a/maquinaria_pesada
# Ruta a ffmpeg (carpeta o ejecutable) si no esta en el PATH del sistema
# FFMPEG_PATH=C:\ruta\a\ffmpeg\bin
